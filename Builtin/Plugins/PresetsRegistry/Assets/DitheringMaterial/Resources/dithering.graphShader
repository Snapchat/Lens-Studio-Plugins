    Node3:
      DependencyIndex: 3
      LevelID: 9
      NodeCount: 0
      NodeType: 1
      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            input_float DitheringSize;
            input_texture_2d ScreenTexture;
            output_float Result;
            
            void main()
            {	
            	vec2 uv = system.getSurfaceUVCoord0();
            	vec2 texSize = ScreenTexture.textureSize();
            	vec2 fragCoord = uv * texSize;
            	float xIndex = floor(mod(fragCoord.x * DitheringSize, 4.0));
            	float yIndex = floor(mod(fragCoord.y * DitheringSize, 4.0));
            	Result = xIndex + yIndex * 4.0;
            }
        Description:
          ClassType1: TEXT
          String: ""
        DitheringSize:
          Connection0:
            NodeLevelID: 29
            PortID: Output
          Variable: 0.0
        Examples:
          ItemIndex: 0
          ItemList: "Custom : Input/Output/Global Types : Extra Functions : Procedural Execution : Lighting Loop : System Built-In Values/Functions"
        ID:
          Variable: 9
        Locked:
          Variable: false
        Result:
          IOType: 1
          Variable: 0.0
        ScreenTexture:
          ClassType2: TEXTURE_OBJECT_2D
          Connection0:
            NodeLevelID: 6
            PortID: Texture
        Stage:
          ItemIndex: 1
          ItemList: "Vertex : Pixel"
        Title:
