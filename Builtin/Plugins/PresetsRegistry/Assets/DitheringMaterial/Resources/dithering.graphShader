    Node11:
      DependencyIndex: 11
      LevelID: 5
      NodeCount: 0
      NodeType: 1
      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            input_int ModeSwitch;
            input_float IndexValue;
            input_float Intensity;
            input_color4 Tint;
            input_color3 ScreenTexture;
            output_vec4 Result;
            
            
            float dither(float c, float i, float v)
            {
            	float closestColor = (c < i) ? 0.0 : 1.0;
            	float secondClosestColor = 1.0 - closestColor;
                float index = v / 16.0;
            	float dis = abs(closestColor - c);
            	return(dis < index) ? closestColor : secondClosestColor;
            }
            
            void main()
            {
            
                if(ModeSwitch == 0){
            	Result = vec4(dither(ScreenTexture.r, Intensity, IndexValue),
            				   dither(ScreenTexture.g, Intensity, IndexValue),
            				   dither(ScreenTexture.b, Intensity, IndexValue), 1.0);
                }
                else{
            	float dotColor = dot(ScreenTexture, vec3(0.3, 0.59, 0.11));
            	Result = vec4(dither(dotColor, Intensity, IndexValue),
            					dither(dotColor, Intensity, IndexValue),
            					dither(dotColor, Intensity, IndexValue),1.0);
                }
                Result *= Tint;
            }
        Description:
          ClassType1: TEXT
          String: ""
        Examples:
          ItemIndex: 0
          ItemList: "Custom : Input/Output/Global Types : Extra Functions : Procedural Execution : Lighting Loop : System Built-In Values/Functions"
        ID:
          Variable: 5
        IndexValue:
          Connection0:
            NodeLevelID: 72
            PortID: Output
          Variable: 0.0
        Intensity:
          Connection0:
            NodeLevelID: 60
            PortID: Output
          Variable: 0.0
        Locked:
          Variable: false
        ModeSwitch:
          Connection0:
            NodeLevelID: 15
            PortID: Output
          Variable: 0.0
        Result:
          IOType: 1
          Variable: [0.0, 0.0, 0.0, 0.0]
        ScreenTexture:
          ClassType1: COLOR
          Connection0:
            NodeLevelID: 11
            PortID: Color
          Variable: [1.0, 1.0, 1.0, 1.0]
        Stage:
          ItemIndex: 1
