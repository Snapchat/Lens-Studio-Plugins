    Node93:
      DependencyIndex: 93
      LevelID: 31
      NodeCount: 0
      NodeType: 1
      Ports:
        Background:
          Connection0:
            NodeLevelID: 3
            PortID: Background
          Variable: [1.0, 1.0, 1.0]
        ClearcoatBase:
          Connection0:
            NodeLevelID: 3
            PortID: ClearcoatBase
          Variable: 0.0
        ClearcoatColor:
          Connection0:
            NodeLevelID: 405
            PortID: Output
          Variable: [0.0, 0.0, 0.0, 0.0]
        Code:
          ClassType1: TEXT
          String: |-
            input_vec4 PbrIn;
            
            input_bool EnableTransmission;
            input_float Opacity;
            input_vec3 Background;
            
            input_bool EnableSheen;
            input_vec4 SheenColor;
            
            input_bool EnableClearcoat;
            input_float ClearcoatBase;
            input_vec4 ClearcoatColor;
            
            output_vec4 Result;
            
            void main()
            {
                Result = PbrIn;
            
                if(EnableSheen || EnableTransmission || EnableClearcoat) {
                    Result = system.srgbToLinear( Result );
            
            		// Sheen
                    if(EnableSheen) {
                        float albedoScaling = SheenColor.a;
                        Result.rgb = (Result.rgb * albedoScaling) + SheenColor.rgb;
                    }
            
                    if(EnableTransmission) {
                        Result = mix(vec4(Background, 1.0), Result, system.srgbToLinear(Opacity));
                        Result.a = 1.0;
                    }
                    
                    if(EnableClearcoat) {
                        vec4 clearcoatFinal = ClearcoatBase * system.srgbToLinear(ClearcoatColor);
                        Result.rgb += clearcoatFinal.rgb;
                    }
            
                    Result = system.linearToSrgb(Result);
                }
            
            }
        CustomCodeNodeAsset:
          ClassType1: REFUID
          String: ""
        Description:
          ClassType1: TEXT
          String: Apply blend for transmission and add sheen and clearcoat.
        EnableClearcoat:
          Connection0:
            NodeLevelID: 411
            PortID: Output
          Wireless: true
          Variable: 0.0
        EnableSheen:
          Connection0:
            NodeLevelID: 33
            PortID: Output
          Wireless: true
          Variable: 0.0
        EnableTransmission:
          Connection0:
            NodeLevelID: 410
            PortID: Output
          Wireless: true
          Variable: 0.0
        Examples:
          ItemIndex: 0
          ItemList: "Custom : Input/Output/Global Types : Extra Functions : Procedural Execution : Lighting Loop : System Built-In Values/Functions"
        ID:
          Variable: 31
        Locked:
          Variable: false
        Opacity:
          Connection0:
            NodeLevelID: 3
            PortID: Opacity
          Variable: 0.0
        PbrIn:
          Connection0:
            NodeLevelID: 36
            PortID: Output
          Variable: [0.0, 0.0, 0.0, 0.0]
        Result:
          IOType: 1
          Variable: [0.0, 0.0, 0.0, 0.0]
        SheenColor:
          Connection0:
            NodeLevelID: 3
            PortID: SheenOut
          Variable: [0.0, 0.0, 0.0, 0.0]
        Stage:
          ItemIndex: 1
