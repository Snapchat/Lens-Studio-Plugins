        Node4:
          DependencyIndex: 9
          LevelID: 12
          NodeCount: 0
          NodeType: 1
          Ports:
            BlurFactor:
              Connection0:
                NodeLevelID: 6
                PortID: Value
              Variable: 0.0
            Code:
              ClassType1: TEXT
              String: |-
                input_texture_2d Texture;
                input_float BlurFactor;
                input_vec2  PixelSize;
                input_vec2  TexCoord;
                
                output_vec4 Result; 
                
                void main()
                {
                	if (BlurFactor <= 0.0) {
                		Result = Texture.sample(TexCoord);
                	}
                	else {
                		const int loopIter = 8;
                		const float loopDenom = 1.0 / float(loopIter);
                
                		vec4 blurredTex = vec4(0.0);
                		float lod = BlurFactor + 0.7;
                
                		vec2 arr[8] = vec2[](vec2( 1.0162,  1.0162),
                						 	vec2( 0.4209,  1.0162),
                						 	vec2(-0.4209,  1.0162),
                						 	vec2(-1.0162,  0.4209),
                						 	vec2(-1.0162, -0.4209),
                						 	vec2(-0.4209, -1.0162),
                						 	vec2( 0.4209, -1.0162),
                						 	vec2( 1.0162, -0.4209));
                
                		for (int i = 0; i < loopIter; i++) {
                			vec2 uvIter = arr[i] * PixelSize * exp2(BlurFactor) + TexCoord;
                			blurredTex += Texture.sampleLod(uvIter, lod) * loopDenom;
                		}
                
                		float fadeOutBlur = min(BlurFactor, 1.0);
                		vec4 baseTex = Texture.sampleLod(TexCoord, lod * fadeOutBlur);
                		Result = mix(baseTex, blurredTex, 0.84 * fadeOutBlur);
                	}
                }
            Description:
              ClassType1: TEXT
              String: ""
            Examples:
              ItemIndex: 0
              ItemList: "Custom : Input/Output/Global Types : Extra Functions : Procedural Execution : Lighting Loop : System Built-In Values/Functions"
            ID:
              Variable: 12
            Locked:
              Variable: false
            PixelSize:
              Connection0:
                NodeLevelID: 7
                PortID: Value
              Variable: [0.0, 0.0]
            Result:
              IOType: 1
              Variable: [0.0, 0.0, 0.0, 0.0]
            Stage:
              ItemIndex: 1
              ItemList: "Vertex : Pixel"
            TexCoord:
              Connection0:
                NodeLevelID: 10
                PortID: Value
              Variable: [0.0, 0.0]
            Texture:
              ClassType2: TEXTURE_OBJECT_2D
              Connection0:
                NodeLevelID: 5
                PortID: Value
            Title:
              String: Gaussian Blur
            ngs_Height:
              Variable: 600
            ngs_Version:
              String: 0.1.0
          PositionX: 310
          PositionY: -130
          TemplateID: node_util_custom
