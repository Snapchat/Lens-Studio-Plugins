            NodeLevelID: 9
            PortID: Output
          Variable: [0.0, 0.0, 0.0, 0.0]
        SubGraphUniqueID7:
          Connection0:
            NodeLevelID: 0
            PortID: PixelSize
          Variable: [0.0, 0.0, 0.0, 0.0]
        Title1:
          String: Gaussian Blur
