      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            input_int MESHTYPE;
            input_vec4 ParticleColor;
            input_bool DO_PBR;
            input_vec4 PBRColor;
            
            output_vec4 Result;
            
            void main()
            {
            	Result = ParticleColor;
            
            	// only do PBR if meshtype is 3D Mesh
            	if(MESHTYPE == 1)
            	{
            		if(DO_PBR)
            		{
            			Result = PBRColor;
            		}
            	}
            }
