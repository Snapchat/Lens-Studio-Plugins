    Node142:
      DependencyIndex: 142
      LevelID: 111
      NodeCount: 0
      NodeType: 1
      Ports:
        ALIGNMENT_OPTION:
          Connection0:
            NodeLevelID: 23
            PortID: Output
          Variable: 0.0
        Code:
          ClassType1: TEXT
          String: |-
            // VERSION NOTES:
            // 2.2.0:   - Custom Force input
            //          - fix bug when size < 1.0
            //          - clean up size parameters:
            //              * make sizeEnd / sizeEndMax the default upper bound instead of sizeStart for sizeRampTex settings
            //              * combine sizeStart and sizeStartMin into same parameter to reduce param count
            //              * add 3D params to allow automatic sorting
            //          - clean up rotation parameters in code node
            //          - turn alignment settings into droplist
            // 2.1.1:	- fixed texturing on trails
            // 2.1.0:   - added trails & trail controls (resulted in some refactoring for compiler)
            //          - renamed variables (defValue > defaultValue, dieTrigger > particleAlive)
            //          - added size ramp toggle so ramp value can be used to interpolate between start/end values (instead of 0 to start)
            //          - slight change to kill vertex code
            // 2.0.5:   - added align to camera options, can now use World Up or Camera Up
            // 2.0.4:	- updated code node version
            // 2.0.3:   - changed quad facing camera calculation
            // 2.0.2:   - added fix for extra scaling with align to direction
            //          - added Screen Fade parameters back in
            // 2.0.1:   - separated Time and Lifetime variables to a new Code Node
            // 2.0.0:   - restructured GPU Particles into 2 Code Nodes (Vertex and Pixel)
            //          - changed mesh to single quad and restructured to use instancing.
            //          - changed the way the particle seed is calculated.
            //          - added "ENABLE_" prefix to all static bools to avoid static bool code node name conflict / bug
            //          - fixed Spawn Duration
            //          - added additional parameters and calculation for 3D mesh (Size, Rotation, Alignment)
            // 1.1.1:   - fixed vertNormal calculation to match legacy so particles always face camera
            // 1.1.0:   - Added ENABLE_FORCE Bool. New feature ENABLE_IGNOREVEL added.
            // 0.1.3:   - Corrected Size drag parameter order.
            // 0.1.2:   - Replaced FallbackMode input to isFallbackMode() function.
            //          - Changed sizeRampTex value from 0.0 to 1.0 for FallbackMode.
            //          - Changed velOut for FallbackMode.
            // 0.1.1:   - Fixed normTime input.
            
            // global variables
            global_vec3 ParticleSpawnPosition;
            
            // Quad or 3D Mesh
            input_bool MESHTYPE_QUAD;
            
            // Seeds
            input_vec3 particleSeedIn;
            input_float globalSeedIn;
            
            // Time / Spawn
            input_float particleAlive;
            input_vec4 timeValuesIn;
            
            // Trails
            input_bool ENABLE_TRAILS;
            input_bool isTrail;
            input_vec2 trailHeadTime;
            input_bool ENABLE_INDEPENDENTTRAIL;
            input_vec2 taper;
            input_bool ENABLE_TRAILSPIN;
            input_float trailSizeMult;
            input_bool ENABLE_TRAILSIZERAMP;
            input_texture_2d trailSizeRampTexture;
            input_bool ENABLE_TRAILSIZERAMPSTARTENDASBOUNDS;
            
            // Vertex Information
            input_vec3 positionObjectSpace;
            input_vec3 normalObjectSpace;
            
            // Spawn Location / Shape
            input_bool ENABLE_INILOCATION;
            input_vec3 spawnLocation;
            input_bool ENABLE_BOXSPAWN;
            input_vec3 spawnBox;
            input_bool ENABLE_SPHERESPAWN;
            input_vec3 spawnSphere;
            
            // Noise
            input_bool ENABLE_NOISE;
            input_vec3 noiseMult;
            input_vec3 noiseFrequency;
            input_bool ENABLE_SNOISE;
            input_vec3 sNoiseMult;
            input_vec3 sNoiseFrequency;
            
            // Velocity
            input_bool ENABLE_VELRAMP;
            input_vec3 velocityMin;
            input_vec3 velocityMax;
            input_vec3 velocityDrag;
            input_texture_2d velRampTexture;
            
            // Particle Size
            input_vec2 sizeStart;
            input_vec2 sizeEnd;
            input_vec2 sizeStartMax;
            input_vec2 sizeEndMax;
            input_vec3 sizeStart3D;
            input_vec3 sizeEnd3D;
            input_vec3 sizeStartMax3D;
            input_vec3 sizeEndMax3D;
            input_float sizeSpeed;
            input_bool ENABLE_SIZEMINMAX;
            input_bool ENABLE_SIZERAMP;
            input_texture_2d sizeRampTexture;
            input_bool ENABLE_SIZERAMPSTARTENDASBOUNDS;
            
            // Forces
            input_float gravity;
            input_bool ENABLE_FORCE;
            input_vec3 localForce;
            input_bool ENABLE_CUSTOMFORCE;
            input_vec3 CustomForce;
            
            // Alignment
            // 0 = direction, 1 = X, 2 = Y, 3 = Z
            input_bool ENABLE_ALIGNMENT;
            input_int ALIGNMENT_OPTION;
            // 0 = world up, 1 = camera up
            input_int QUAD_ALIGNMENT;
            input_float sizeVelScale;
            input_bool ENABLE_IGNOREVEL;
            input_bool ENABLE_IGNORETRANSFORMSCALE;
            input_vec2 velScaleMinMax;
            
            // Rotation
            input_vec2 rotationRandom;
            input_vec2 rotationRate;
            input_vec2 rotationRandomX;
            input_vec2 rotationRateX;
            input_vec2 rotationRandomY;
            input_vec2 rotationRateY;
            input_vec2 rotationRandomZ;
            input_vec2 rotationRateZ;
            input_float rotationDrag;
            input_bool WORLDSPACE;
            input_bool WORLDFORCE;
            input_bool ENABLE_CENTER_IN_BBOX;
            
            // Screen Fade
            input_bool ENABLE_SCREENFADE;
            input_float fadeDistanceVisible;
            input_float fadeDistanceInvisible;
            
            // OUTPUT
            output_vec3 particleSeed;
            output_float globalSeed;
            // xy = lifeTimeMinMax.xy, z = localTime, w = normTime
            output_vec4 timeValues;
            // output_float nearCameraFade;
            output_vec4 cameraFade_trailHeadTime_taper;
            output_vec3 position;
            output_vec3 normal;
            
            ///////////////////////////////////////////////////////////////////////////////
            //  CONSTANTS AND GLOBALS
            ///////////////////////////////////////////////////////////////////////////////
            const float EPSILON = 1e-6;
            const float PI = 3.14159265359;
            const int ALIGN_DIRECTION = 0;
            const int ALIGN_X = 1;
            const int ALIGN_Y = 2;
            const int ALIGN_Z = 3;
            
            // ----- clean up size UI
            vec3 sizeStart_actual       = vec3(0.0);
            vec3 sizeStartMax_actual    = vec3(0.0);
            vec3 sizeEnd_actual         = vec3(0.0);
            vec3 sizeEndMax_actual      = vec3(0.0);
            
            ///////////////////////////////////////////////////////////////////////////////
            //  FUNCTIONS
            ///////////////////////////////////////////////////////////////////////////////
            
            // Tranpose -- used to help create sc_NormalMatrixInverse
            mat3 transposeMatrix(mat4 matrix)
            {
                vec4 row0 = matrix[0];
                vec4 row1 = matrix[1];
                vec4 row2 = matrix[2];
                mat3 result = mat3(
                    vec3(row0.x, row1.x, row2.x),
                    vec3(row0.y, row1.y, row2.y),
                    vec3(row0.z, row1.z, row2.z));
                return result;
            }
            
            // Particle Size -- Quad Particle (original)
            vec2 pSize(float random1, float random2, float timeIn, float sizeSpeed)
            {
                vec2 psizeStart = vec2(0.0);
                vec2 psizeEnd = vec2(0.0);
                float normTime = timeIn;
            
                if (ENABLE_TRAILS)
                {
                    if ( !ENABLE_INDEPENDENTTRAIL )
                    {
                        normTime = trailHeadTime.y;
                    }
                }
            
                float sizePow = pow(normTime, sizeSpeed);
                // 2.2.0: organize size UI parameters.
                // if trails are being used with a 3D mesh, trails will switch to use 3D parameters instead of 2D for simpler UI
                if (ENABLE_SIZEMINMAX) {
                    if (MESHTYPE_QUAD)  { psizeStart = mix(sizeStart, sizeStartMax, random1);           }
                    else                { psizeStart = mix(sizeStart3D.xy, sizeStartMax3D.xy, random1); }
            
                    if(ENABLE_SIZERAMP) {
                        if(ENABLE_SIZERAMPSTARTENDASBOUNDS) {
                            if (MESHTYPE_QUAD)  { psizeEnd = mix(sizeEnd, sizeEndMax, random2);             }
                            else                { psizeEnd = mix(sizeEnd3D.xy, sizeEndMax3D.xy, random1);   }
                        }
                    } else {
                        if (MESHTYPE_QUAD)  { psizeEnd = mix(sizeEnd, sizeEndMax, random2);             }
                        else                { psizeEnd = mix(sizeEnd3D.xy, sizeEndMax3D.xy, random1);   }
                    }
                } else {
                    if(MESHTYPE_QUAD)   { psizeStart = sizeStart;       }
                    else                { psizeStart = sizeStart3D.xy;  }
            
                    if(ENABLE_SIZERAMP) {
                        if(ENABLE_SIZERAMPSTARTENDASBOUNDS) {
                            if(MESHTYPE_QUAD)   { psizeEnd = sizeEnd;       }
                            else                { psizeEnd = sizeEnd3D.xy;  }
                        }
                    } else {
                        if(MESHTYPE_QUAD)   { psizeEnd = sizeEnd;       }
                        else                { psizeEnd = sizeEnd3D.xy;  }
                    }
                }
                vec2 sizeLife = mix(psizeStart, psizeEnd, sizePow);
            
                // if older device, do not use size ramp
                if (system.isFallbackMode()) return sizeLife;
            
                if (ENABLE_SIZERAMP)
                {
                        float sizeRampPanning = ceil(normTime * 10000.0) / 10000.0;
                        vec2 sizeRampUV = system.getSurfaceUVCoord0() / vec2(10000.0, 1.0) + vec2(sizeRampPanning, 0.0);
                        vec2 sizeRampTex = sizeRampTexture.sample(sizeRampUV).rg;
            
                        sizeLife = sizeRampTex * psizeStart;
                        // 2.1.0 - add option to use the start/end values as lower and upper bounds
                        // 2.2.0 - swap size start and size end so size start is always the upper bound (maintain legacy behavior)
                        if(ENABLE_SIZERAMPSTARTENDASBOUNDS)
                        {
                            sizeLife = mix(psizeEnd, psizeStart, sizeRampTex);
                        }
                }
            
                // 2.1.0 -- enable trails.
                if (ENABLE_TRAILS)
                {
                    if(isTrail)
                    {
                        if (ENABLE_TRAILSIZERAMP)
                        {
                            normTime = timeIn;
                            float sizeRampPanning = ceil(normTime * 10000.0) / 10000.0;
                            vec2 sizeRampUV = system.getSurfaceUVCoord0() / vec2(10000.0, 1.0) + vec2(sizeRampPanning, 0.0);
                            float sizeRampTex = trailSizeRampTexture.sample(sizeRampUV).r; // 2.1.0 - override size ramp if using
            
                            // use 3D parameters
                            sizeLife.x = sizeRampTex * psizeStart.x;
                            // 2.1.0 - add option to use the start/end values as lower and upper bounds
                            // 2.2.0 - swap size start and size end so size start is always the upper bound (maintain legacy behavior)
                            if(ENABLE_TRAILSIZERAMPSTARTENDASBOUNDS)
                            {
                                sizeLife.x = mix(psizeEnd.x, psizeStart.x, sizeRampTex);
                            }
                        }
                        sizeLife.x *= trailSizeMult;
                        sizeLife.y = 0.0; // force height to 0 since trails only need width 
                    }
                }
            
                return sizeLife;
            }
            
            
            // Particle Size - 3D Particle
            vec3 pSize3D(float random1, float random2, float normTime, float sizeSpeed)
            {
                vec3 psizeStart = vec3(0.0);
                vec3 psizeEnd = vec3(0.0);
                float sizePow = pow(normTime, sizeSpeed);
            
                // 2.2.0 clean up size ui
                if (ENABLE_SIZEMINMAX)
                {
                    psizeStart = mix(sizeStart3D, sizeStartMax3D, random1);
                    if(ENABLE_SIZERAMP) {
                        if(ENABLE_SIZERAMPSTARTENDASBOUNDS) psizeEnd = mix(sizeEnd3D, sizeEndMax3D, random2);
                    } else {
            		    psizeEnd = mix(sizeEnd3D, sizeEndMax3D, random2);
                    }
                } else {
                    psizeStart = sizeStart3D;
                    if(ENABLE_SIZERAMP) {
                        if(ENABLE_SIZERAMPSTARTENDASBOUNDS) psizeEnd = sizeEnd3D;
                    } else {
                        psizeEnd = sizeEnd3D;
                    }
                }
                vec3 sizeLife = mix(psizeStart, psizeEnd, sizePow);
            
                // if older device, do not use size ramp
                if (system.isFallbackMode()) return sizeLife;
            
                if (ENABLE_SIZERAMP)
                {
                    float sizeRampPanning = ceil(normTime * 10000.0) / 10000.0;
                    vec2 sizeRampUV = system.getSurfaceUVCoord0() / vec2(10000.0, 1.0) + vec2(sizeRampPanning, 0.0);
                    vec3 sizeRampTex = sizeRampTexture.sample(sizeRampUV).rgb;
            
                    sizeLife = sizeRampTex * psizeStart;
                    // 2.1.0 - add option to use the start/end values as lower and upper bounds
                    // 2.2.0 - swap sizeStart3D and sizeEnd3D so sizeStart3D is always the upper bound (maintain legacy behavior)
                    if(ENABLE_SIZERAMPSTARTENDASBOUNDS) sizeLife = mix(psizeEnd, psizeStart, sizeRampTex);
                }
                return sizeLife;
            }
            
            // Noise Util - Permute
            vec3 permute(vec3 x) { return mod(((x * 34.0) + 1.0) * x, 289.0); }
            
            // Noise Util - Simplex 2D
            float sNoise(vec2 v)
            {
                const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
                vec2 i = floor(v + dot(v, C.yy));
                vec2 x0 = v - i + dot(i, C.xx);
                vec2 i1;
                i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
                vec4 x12 = x0.xyxy + C.xxzz;
                x12.xy -= i1;
                i = mod(i, 289.0);
                vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
                vec3 m = max(0.5 - vec3(dot(x0, x0), dot(x12.xy, x12.xy), dot(x12.zw, x12.zw)), 0.0);
                m = m * m;
                m = m * m;
                vec3 x = 2.0 * fract(p * C.www) - 1.0;
                vec3 h = abs(x) - 0.5;
                vec3 ox = floor(x + 0.5);
                vec3 a0 = x - ox;
                m *= 1.79284291400159 - 0.85373472095314 * (a0 * a0 + h * h);
                vec3 g;
                g.x = a0.x * x0.x + h.x * x0.y;
                g.yz = a0.yz * x12.xz + h.yz * x12.yw;
                return 130.0 * dot(m, g);
            }
            
            // Particle Noise - Simplex
            vec3 simplexNoise(float randX, float randY, float randZ, vec3 sNoiseFrequency, vec3 sNoiseMult, vec3 random, float time)
            {
                float sNoiseX = sNoise(vec2(randX * time, sNoiseFrequency.x));
                float sNoiseY = sNoise(vec2(randY * time, sNoiseFrequency.y));
                float sNoiseZ = sNoise(vec2(randZ * time, sNoiseFrequency.z));
                return vec3(sNoiseX, sNoiseY, sNoiseZ) * sNoiseMult * random;
            }
            
            // Particle Noise - Sine
            vec3 sineNoise(vec3 noiseFrequency, vec3 noiseMult, vec3 random, float time)
            {
                float noiseX = sin(time * noiseFrequency.x);
                float noiseY = sin(time * noiseFrequency.y);
                float noiseZ = sin(time * noiseFrequency.z);
                vec3 noiseMix = vec3(noiseX, noiseY, noiseZ) * noiseMult * random;
                return noiseMix;
            }
            
            // Particle Velocity
            vec3 pVelocity(vec3 velRange, float localTime, vec3 velocityDrag, vec3 noiseXYZValue, float normTime)
            {
                vec3 velDrag = pow(vec3(localTime, localTime, localTime), velocityDrag);
            
                vec3 velOut = (velRange + noiseXYZValue) * velDrag;
                if (ENABLE_VELRAMP)
                {
                    float velRampPanning = floor(normTime * 10000.0) / 10000.0;
                    vec2 velRampUV = system.getSurfaceUVCoord0() / vec2(10000.0, 1.0) + vec2(velRampPanning, 0.0);
                    vec3 velRampTex = velRampTexture.sample(velRampUV).xyz;
                    velOut = (velRange + noiseXYZValue) * velRampTex;
            
                    if (system.isFallbackMode())
                    {
                        velOut = velRange * velDrag;
                    }
                }
                return velOut;
            }
            
            // 2.2.0 - clean up alignment UI
            // move align to vel for Trails and Quads into their own functions for better UI sorting
            
            // Align to Velocity -- Quads
            void AlignToVel_Quad(inout float velLength, inout vec3 sideVecRot, inout vec3 upVecRot, vec3 vertNormal, vec3 worldPosRelToSpawn, vec3 gravityWorld, vec3 localForceWorld, vec3 customForce, mat3 particleToWorldMatrix)
            {
                // 2.2.0: add custom force into vel scale, simplify calculation (same formula)
                vec3 velocityDir = normalize(worldPosRelToSpawn + gravityWorld + localForceWorld + customForce + EPSILON);
                vec3 baseVel = worldPosRelToSpawn * 0.02;
                sideVecRot = velocityDir;
                upVecRot = normalize(cross(sideVecRot, vertNormal));
            
                if (ENABLE_IGNOREVEL)
                {
                    // 1.1.0 Petro's code doesn't match the original look, artists requested to revert.
                    velLength = max(sizeVelScale, EPSILON);
                }
                else
                {
                    // 2.0.2: fix for velocity stretching -- by default, the system also applies extra stretching
                    // based on the transform (world) scale. This toggle allows you to ignore the world scale.
                    if(ENABLE_IGNORETRANSFORMSCALE)
                    {
                        velLength = (length(baseVel) / length(system.getMatrixWorld()[0].xyz)) * sizeVelScale;
                    } else {
                        // original calculation -- the stretch is affected by transform scale (e.g. larger systems stretch more)
                        // this matches the default legacy "align to direction" behavior
                        velLength = length(baseVel) * sizeVelScale;
                    }
            
                    // 2.2.0 - add option for vel scale clamping
                    velLength = clamp(velLength, velScaleMinMax.x, velScaleMinMax.y);
                }
            }
            
            // Align to Velocity - trails (does not apply vel stretching)
            void AlignToVel_Trail(inout vec3 sideVecRot, inout vec3 upVecRot, vec3 vertNormal, vec2 rotatedXAxis, vec3 worldPosRelToSpawn, vec3 gravityWorld, vec3 localForceWorld, vec3 customForce)
            {
                // 2.2.0: organize code
                vec3 baseVel = (0.02 * worldPosRelToSpawn) + gravityWorld + localForceWorld + customForce + EPSILON;
                vec3 velocityDir = normalize(baseVel);
                sideVecRot = velocityDir;
                upVecRot = normalize(cross(sideVecRot, vertNormal));
            
                if(ENABLE_TRAILSPIN)
                {
                    upVecRot = vec3(sideVecRot * rotatedXAxis.x + upVecRot * rotatedXAxis.y);
                }
            }
            
            void main()
            {
            
                ///////////////////////////////////////////////////////////////////////////
                //  RANDOMIZED VARIABLES
                ///////////////////////////////////////////////////////////////////////////
                vec3 defaultValue = vec3(0.0, 0.0, 0.0);
            
                // 2.0.1 Moved particle seed calculation to Spawn / Time / Seed code node
                // 2.0.0 Change particles to use instancing
                // Previously, each particle's ID was stored as a color and calculated using the following formula:
                //      vec4 color = system.getSurfaceColor();
                //      float colorRGB = color.r + color.g * color.b;
                // colorRGB has been replaced with vec3 particleSeed
                particleSeed = particleSeedIn;
                globalSeed = globalSeedIn;
            
                // system.getInstanceRatio() potentially gets better distribution, but this has more true randomness
                float randPosX = particleSeed.x;
                float randPosY = particleSeed.y;
                float randPosZ = particleSeed.z;
                vec3 randBoxSpawn = fract(vec3(randPosX, randPosY, randPosZ) * 3048.28 + globalSeed) - 0.5;
            
                // 2.0.0: adjust sphere spawn calculataion to work with instancing
                // may need to prevent normalize in case randDirection = (0,0,0) 
                vec3 randDirection = fract(particleSeed * 374.5713 + globalSeed) - 0.5;
                vec3 randSphereSpawn = normalize(randDirection + EPSILON);
                float sphereSeed = fract(particleSeed.x + globalSeed);
                float randRadius = pow(sphereSeed, 1.0 / 3.0);
                randSphereSpawn *= randRadius;
                randSphereSpawn /= 2.0;
            
                // Size
                // 2.2.0 - fix random size seed calculation it should be a [0,1] value not [-0.5, 0.5] because its used in a mix()
                float randSize1 = fract(particleSeed.x * 334.59123123 + globalSeed);
                float randSize2 = fract(particleSeed.y * 41.23123 + globalSeed);
            
                // Noise & Velocity
                float randX = fract(particleSeed.z * 18.98453 + globalSeed);
                float randY = fract(particleSeed.x * 654.1559 + globalSeed);
                float randZ = fract(particleSeed.y * 45.72241 + globalSeed);
                vec3 randVel = (vec3(randY, randZ, randX) - 0.5) * 2.0;
                vec3 randRampVel = vec3(randY, randZ, randX);
            
                // Rotation
                float randIniRotZ = fract(particleSeed.z * 15.32451 + globalSeed);
            
            
                ///////////////////////////////////////////////////////////////////////////
                //  PARTICLE CONDITIONS
                ///////////////////////////////////////////////////////////////////////////
            
                // ------ Time, Lifetime, Spawn -------------------------------------------
                // 2.0.1: Moved Time, Spawn, and Seed calculations to Time / Spawn / Seed Code node
                // xy = lifeTimeMinMax.xy, z = localTime, w = normTime
                vec2 realLifeTimeMinMax = timeValuesIn.xy;
                float localTime = timeValuesIn.z;
                float normTime = timeValuesIn.w;
                cameraFade_trailHeadTime_taper = vec4(0.0);
                
                // ------ Location --------------------------------------------------------
                vec3 calspawnBox = defaultValue;
                vec3 calspawnSphere = defaultValue;
                vec3 iniLoc = defaultValue;
            
                if (ENABLE_INILOCATION)
                {
                    iniLoc = spawnLocation;
                }
                if (ENABLE_BOXSPAWN)
                {
                    calspawnBox = spawnBox * randBoxSpawn;
                }
                if (ENABLE_SPHERESPAWN)
                {
                    calspawnSphere = spawnSphere * randSphereSpawn;
                }
            
                vec3 spawnLoc = iniLoc + calspawnSphere + calspawnBox;
            
            
                // ------ Forces ----------------------------------------------------------
                // Noise
                vec3 noiseXYZ = defaultValue;
                if (ENABLE_NOISE)
                {
                    noiseXYZ += sineNoise(noiseFrequency, noiseMult, randVel, normTime);
                }
                if (ENABLE_SNOISE)
                {
                    noiseXYZ += simplexNoise(randX, randY, randZ, sNoiseFrequency, sNoiseMult, randVel, localTime);
                }
            
                // Gravity / Local / World 
                vec3 gravityWorld = vec3(0.0, gravity / 2.0 * localTime * localTime, 0.0);
                vec3 localForceWorld = defaultValue;
                if (ENABLE_FORCE)
                {
                    localForceWorld = localForce / 2.0 * localTime * localTime;
                }
            
                // 2.2.0 custom force
                vec3 customForce = defaultValue;
                if(ENABLE_CUSTOMFORCE)
                {
                    ParticleSpawnPosition = spawnLoc;
                    customForce = CustomForce.evaluate() / 2.0 * localTime * localTime;
                }
            
                // ------ Velocity -----------------------------------------------------
                vec3 velocityXYZ = defaultValue;
                vec3 velRange = velocityMin + (((randVel + 1.0) / (2.0)) * (velocityMax - velocityMin));
                if (ENABLE_VELRAMP)
                {
                    velRange = mix(velocityMin, velocityMax, randRampVel);
                }
                velocityXYZ = pVelocity(velRange, localTime, velocityDrag, noiseXYZ, normTime);
            
                // ------ Trails 2.1.0 -------------------------------------------------------
                if(ENABLE_TRAILS) {
                    if(isTrail) {
                        vec2 uv0 = system.getSurfaceUVCoord0();
                        float taperFactor = mix(1.0, uv0.y, 1.0 - taper.x); // taper front
                        taperFactor *= mix(1.0, 1.0 - uv0.y, 1.0 - taper.y); // taper end
                        cameraFade_trailHeadTime_taper.yz = trailHeadTime; // send trailHeadTime to interpolater
                        cameraFade_trailHeadTime_taper.w = taperFactor; // 2.1.1 send taper width to fragment shader to fix UVs
                    }
                }
            
                ///////////////////////////////////////////////////////////////////////////
                //  CALCULATE POSITION AND NORMAL
                ///////////////////////////////////////////////////////////////////////////
            
                // --- Calculate Particle Center Position in Worldspace -------------------
            
                // Get scale of entire system
                float scale_x = length(system.getMatrixWorld()[0].xyz);
                float scale_y = length(system.getMatrixWorld()[1].xyz);
                float scale_z = length(system.getMatrixWorld()[2].xyz);
                vec3 worldScale = vec3(scale_x, scale_y, scale_z);
            
                // World space position of the particle relative to its spawn point.
                // 2.2.0 create reference to transposed matrix so we don't call transpose multiple times
                // move localspace calculation into branch so we don't calculate it every time (removes one matrix math)
                mat3 particleToWorldMatrix = transposeMatrix(system.getMatrixWorld());
                vec3 worldPosRelToSpawn;
            
                if (WORLDFORCE)
                {   // velocity and initial positions are local, but forces are world
                    worldPosRelToSpawn = (velocityXYZ * particleToWorldMatrix) + gravityWorld + localForceWorld + customForce;
                }
                else if (WORLDSPACE)
                {   // all calculations are world
                    worldPosRelToSpawn = (velocityXYZ * worldScale) + gravityWorld + localForceWorld + customForce;
                } else
                {   // all calculations are local
                    worldPosRelToSpawn = (velocityXYZ + gravityWorld + localForceWorld + customForce) * particleToWorldMatrix;
                }
            
                vec3 worldPosCenter = (system.getMatrixWorld() * vec4(spawnLoc, 1.0)).xyz + worldPosRelToSpawn;
            
                // Calculate Rotation about Z axis (shared by Quad and 3D mesh types)
                // 2.2.0 organize parameters in code node instead of main graph
                float iniRotation = (MESHTYPE_QUAD) ? mix(rotationRandom.x, rotationRandom.y, randIniRotZ) : mix(rotationRandomZ.x, rotationRandomZ.y, randIniRotZ);
                float rotDragPow = 1.0;
                if(!ENABLE_ALIGNMENT) rotDragPow = pow(1.0 - normTime, rotationDrag);
                float rotationRateRange = (MESHTYPE_QUAD) ? mix(rotationRate.x, rotationRate.y, randIniRotZ) : mix(rotationRateZ.x, rotationRateZ.y, randIniRotZ);
                float rotationByLife = rotationRateRange * rotDragPow * normTime * 2.0;
                float rotation = PI * (rotationByLife + iniRotation - 0.5);
            
                // 2.0.2: Calculate Screen Fade (Fade Close to Camera)
                float cameraFadeKillTrigger = 1.0;
                if(ENABLE_SCREENFADE){
                    vec3 delta = system.getCameraPosition() - worldPosCenter;
                    float distSquared = dot(delta, delta);
                    float visibleDistSq = (fadeDistanceInvisible + EPSILON) * (fadeDistanceInvisible + EPSILON);
                    float invisibleDistSq = fadeDistanceVisible * fadeDistanceVisible;
                    float fadeStart = min(visibleDistSq, invisibleDistSq);
                    float fadeEnd = max(visibleDistSq, invisibleDistSq);
                    float nearCameraFade = smoothstep(fadeStart, fadeEnd, distSquared);
                    nearCameraFade = (visibleDistSq > invisibleDistSq ? 1.0 - nearCameraFade : nearCameraFade);
                    if(nearCameraFade <= EPSILON) { cameraFadeKillTrigger = 0.0; }
                    cameraFade_trailHeadTime_taper.x = nearCameraFade;
                }
            
                // --- Apply Scaling, Rotation, and Translation based on Mesh Type --------
                if(MESHTYPE_QUAD || ENABLE_TRAILS){
                    if(MESHTYPE_QUAD || isTrail){
                        // --------------------------------------------------------------------
                        // QUAD
                        // --------------------------------------------------------------------
            
                        // 2.0.3: update quad facing camera calculation; works similar to VFX, faces the camera plane aligned to camera up
                        // 2.0.5 - add option to have quads use world up instead of camera up, match VFX align to cam better
                        vec3 vertNormal = normalize(system.getMatrixCamera()[2].xyz);
                        if(isTrail) vertNormal *= vec3(-1.0);
                        vec3 quadTangent = vec3(0.0, 1.0, 0.0); // align to camera using world up
                        if(QUAD_ALIGNMENT == 1) quadTangent = system.getCameraUp(); // align to camera using camera up
                        
                        // sideVec = quadBitangent
                        vec3 sideVec = -normalize(cross(vertNormal, quadTangent));
                        // upVec = vertTangent
                        vec3 upVec = normalize(cross(sideVec, vertNormal));
                    
                        float velLength = 1.0;
            
                        if(ENABLE_ALIGNMENT){
                            if (ALIGNMENT_OPTION == ALIGN_X)
                            {
                                sideVec = vec3(0.0, 0.0, 1.0);
                                upVec = vec3(0.0, 1.0, 0.0);
                            }
                            if (ALIGNMENT_OPTION == ALIGN_Y)
                            {
                                sideVec = vec3(1.0, 0.0, 0.0);
                                upVec = vec3(0.0, 0.0, 1.0);
                            }
                            if (ALIGNMENT_OPTION == ALIGN_Z)
                            {
                                sideVec = vec3(1.0, 0.0, 0.0);
                                upVec = vec3(0.0, 1.0, 0.0);
                            }
                        }
            
                        vec2 rotatedXAxis = vec2(cos(rotation), sin(rotation));
                        vec2 rotatedYAxis = vec2(-sin(rotation), cos(rotation));
                        vec3 sideVecRot = vec3(sideVec * rotatedXAxis.x + upVec * rotatedXAxis.y);
                        vec3 upVecRot = vec3(sideVec * rotatedYAxis.x + upVec * rotatedYAxis.y);
            
                        // 2.2.0 refactor alignment code for better UI and code clarity
                        if(ENABLE_ALIGNMENT) {
                            if(ALIGNMENT_OPTION == ALIGN_DIRECTION) {
                                if(!isTrail) AlignToVel_Quad(velLength, sideVecRot, upVecRot, vertNormal, worldPosRelToSpawn, gravityWorld, localForceWorld, customForce, particleToWorldMatrix);
                            }
                        }
                        if(ENABLE_TRAILS) {
                            if(isTrail) {
                                AlignToVel_Trail(sideVecRot, upVecRot, vertNormal, rotatedXAxis, worldPosRelToSpawn, gravityWorld, localForceWorld, customForce);
                            }
                        }
            
            
                        // Output Quad
                        float objScale = length(system.getMatrixWorld()[0].xyz);
                        vec2 quadCornerOffset = cameraFadeKillTrigger * (system.getSurfaceUVCoord0() - vec2(0.5, 0.5)) * pSize(randSize1, randSize2, normTime, sizeSpeed) * objScale;
                        vec3 worldPosCorner = worldPosCenter + upVecRot * quadCornerOffset.x + sideVecRot * (quadCornerOffset.y * velLength);
                        position = worldPosCorner;
            
                        // 2.1.0 - kill vertex by setting to NaN -- may still need to optimize / move further up the graph
                        if(particleAlive < 0.5 || cameraFadeKillTrigger < 0.5) position /= 0.0;
                        normal = vertNormal;
                    }
                }
            
                if(!MESHTYPE_QUAD)
                {
                    if(!isTrail)
                    {
                        // --------------------------------------------------------------------
                        // 3D MESH
                        // --------------------------------------------------------------------
                        // get initial position and center around local origin
                        position = positionObjectSpace;
                        if(ENABLE_CENTER_IN_BBOX){
                            vec3 bboxOffset = (system.getAABBMaxLocal() + system.getAABBMinLocal()) / 2.0;
                            position -= bboxOffset;
                        }
                        
                        // ------ Scale --------------------------------------------------------
                        position = position * worldScale * pSize3D(randSize1, randSize2, normTime, sizeSpeed);
                        // if particle is dead, discard vertex
                        if (particleAlive < 0.5 || cameraFadeKillTrigger < 0.5) { position.x = float(1/0); }
                        
                        // ------ Rotation -----------------------------------------
                        mat3 RotationMatrix3D;
                        // 2.2.0: turn alignment settings into droplist
                        if(ENABLE_ALIGNMENT)
                        {
                            // if Align to Z, use identity matrix (object already faces forward)
                            if(ALIGNMENT_OPTION == ALIGN_Z){
                                RotationMatrix3D = mat3(1.0);
                            } else {
                                // Align to Axis / Velocity using Angle-Axis rotation
                                vec3 velocityDir;
                                if(ALIGNMENT_OPTION == ALIGN_X) { velocityDir = vec3(1.0, 0.0, 0.0); } // align to X
                                if(ALIGNMENT_OPTION == ALIGN_Y) { velocityDir = vec3(0.0, 1.0, 0.0); } // align to Y
                                if(ALIGNMENT_OPTION == ALIGN_DIRECTION) // align to velocity
                                {
                                    // get previous velocity, gravity, and localForce
                                    float timeDiff = 0.001; // deltaTime can also be used, but can have issues when time is very slow
                                    vec3 prevVelocity = pVelocity(velRange, localTime - timeDiff, velocityDrag, noiseXYZ, normTime - timeDiff);
                                    float prevGravity = gravity / 2.0 * (localTime - timeDiff) * (localTime - timeDiff);
                                    gravityWorld.y -= prevGravity;
                                    if(ENABLE_FORCE){
                                        vec3 prevLocalForce = vec3(localForce / 2.0 * (localTime - timeDiff) * (localTime - timeDiff));
                                        localForceWorld -= prevLocalForce;
                                    }
                                    if(ENABLE_CUSTOMFORCE) {
                                        ParticleSpawnPosition = spawnLoc;
                                        vec3 prevCustomForce = CustomForce.evaluate() / 2.0 * (localTime - timeDiff) * (localTime - timeDiff);
                                        customForce -= prevCustomForce;
                                    }
            
                                    // 2.2.0 - custom force input with align to vel                  
                                    // get the direction, accounting for rotation space; these equations are based on those used for worldSpaceRelToSpawn 
                                    if (WORLDFORCE)         { velocityDir = (velocityXYZ - prevVelocity) * particleToWorldMatrix + gravityWorld + localForceWorld + customForce;}
                                    else if (WORLDSPACE)    { velocityDir = (velocityXYZ - prevVelocity) + gravityWorld + localForceWorld + customForce;  }
                                    else                    { velocityDir = ((velocityXYZ - prevVelocity) + localForceWorld + gravityWorld + customForce) * particleToWorldMatrix;}
                                    velocityDir = normalize(velocityDir + EPSILON);
                                }
            
                                // this assumes object's local forward is +z (0, 0, 1) 
                                // the object "faces forward" when it has a rotation of 0,0,0 in studio
                                vec3 forwardVec = vec3(0.0, 0.0, 1.0);
                                vec3 rotationAxis = cross(velocityDir, forwardVec);
                                
                                // Modified Angle-Axis formula from Construct Matrix node
                                vec3  a = normalize(rotationAxis);
                                float s = length(rotationAxis); // sin = length of cross product, since magnitude both vectors is 1
                                float c = dot(forwardVec, velocityDir); // cos = dot product, since magnitude of both vectors is 1
                                float oc = 1.0 - c;
                        
                                RotationMatrix3D = mat3 (
                                    oc * a.x * a.x + c,        oc * a.x * a.y - a.z * s,  oc * a.z * a.x + a.y * s,
                                    oc * a.x * a.y + a.z * s,  oc * a.y * a.y + c,        oc * a.y * a.z - a.x * s,
                                    oc * a.z * a.x - a.y * s,  oc * a.y * a.z + a.x * s,  oc * a.z * a.z + c      
                                );
                            }
            
                            // get rotation about object's z axis
                            mat3 zAxisRotation = mat3(
                                cos(rotation),  -sin(rotation), 0,
                                sin(rotation),   cos(rotation), 0,
                                0,               0,             1
                            );
            
                            RotationMatrix3D =  RotationMatrix3D * zAxisRotation;
            
                            // 2.2.0 change alignment settings configuration
                            if(ENABLE_ALIGNMENT) {
                                if(ALIGNMENT_OPTION == ALIGN_DIRECTION) {
                                    if (!ENABLE_IGNOREVEL)
                                    {
                                        // if scaling by velocity, apply additional scale before rotation along local z axis
                                        float velLength = max(length(0.02 * worldPosRelToSpawn), 1.0) * max(sizeVelScale, EPSILON);
                                        velLength = clamp(velLength, velScaleMinMax.x, velScaleMinMax.y);
                                        position.z *= velLength;
                                    }
                                }
                            }
                        } 
                        else
                        {
                            // rotate using XYZ axis rotations
                            // Z rotation and Rotation Drag already calculated, shared by Quads and 3D Mesh
                            float randIniRotX = fract(particleSeed.x * 92.65301 + globalSeed);
                            float iniRotationX = mix(rotationRandomX.x, rotationRandomX.y, randIniRotX);
                            float rotationRateRangeX = mix(rotationRateX.x, rotationRateX.y, randIniRotX);
                            float rotationByLifeX = rotationRateRangeX * rotDragPow * normTime * 2.0;
            
                            float randIniRotY = fract(particleSeed.y * 6.755756 + globalSeed);
                            float iniRotationY = mix(rotationRandomY.x, rotationRandomY.y, randIniRotY);
                            float rotationRateRangeY = mix(rotationRateY.x, rotationRateY.y, randIniRotY);
                            float rotationByLifeY = rotationRateRangeY * rotDragPow * normTime * 2.0;
            
                            float rotationX = PI * (rotationByLifeX + iniRotationX);
                            float rotationY = PI * (rotationByLifeY + iniRotationY);
                            float rotationZ = PI * (rotationByLife + iniRotation);
            
                            vec3 RotationXYZ = vec3(rotationX, rotationY, rotationZ);
            
                            // construct rotation matrix
                            float cx = cos( RotationXYZ.x );
                            float sx = sin( RotationXYZ.x );
                            float cy = cos( RotationXYZ.y );
                            float sy = sin( RotationXYZ.y );
                            float cz = cos( RotationXYZ.z );
                            float sz = sin( RotationXYZ.z );
                        
                            RotationMatrix3D = mat3(
                                cy * cz,    cx * sz + sx * sy * cz,     sx * sz - cx * sy * cz,
                                -cy * sz,   cx * cz - sx * sy * sz,     sx * cz + cx * sy * sz,
                                sy,         -sx * cy,                   cx * cy
                            );
                        }
            
                        // if using Rotation = Local Space or World Force and not aligning to velocity, rotate around local XYZ axis
                        if(!WORLDSPACE){
                            if(!ENABLE_ALIGNMENT){ // 2.2.0 change alignment settings configuration
                                // extract rotation from Transform
                                mat3 LocalRotation = mat3(
                                    system.getMatrixWorld()[0].xyz / worldScale.x,
                                    system.getMatrixWorld()[1].xyz / worldScale.y,
                                    system.getMatrixWorld()[2].xyz / worldScale.z
                                );
                                RotationMatrix3D = LocalRotation * RotationMatrix3D;
                            }
                        }
            
                        // apply rotation matrix
                        position = RotationMatrix3D * position;
                        normal = normalize(RotationMatrix3D * normalObjectSpace);
            
                        // ------ Place in World ----------------------------------------------
                        position = position + worldPosCenter;
                    }
                }
            
                // package output variables
                timeValues = vec4(realLifeTimeMinMax, localTime, normTime);
            }
