    Node119:
      DependencyIndex: 119
      LevelID: 223
      NodeCount: 0
      NodeType: 1
      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            // Custom Force GPU Particles
            input_vec3 ParticleSpawnPosition;
            input_vec3 ParticleSeed;
            input_vec4 timeValues;
            input_float Strength;
            input_vec3 ForceOrigin;
            
            output_vec3 CustomForce;
            
            // helpful variables:
            // localTime = timeValues.z -- the time value local to the particle, beginning at particle spawn
            // normTime = timeValues.w -- the normalized time value of the current particle (0 = beginning of particle life, 1 = end of particle life)
            // ParticleSpawnPosition -- the initial spawn location of the particle, calculated in the vertex shader
            
            vec3 calculateForceAttractRepel(vec3 forceOrigin, vec3 particlePosition, float strength) {
                vec3 forceDir;
                // if the force origin and particle position are exactly the same, generate a normalized force
                // this is useful when particles have no other forces or velocities acting on them
                if(forceOrigin == particlePosition) forceDir = normalize( (system.getRandomVec3( ParticleSeed * float(system.getInstanceCount()) ) - 0.5) * 2.0 );
                else								forceDir = normalize(forceOrigin - particlePosition);
            
                return forceDir * strength;
            }
            
            void main()
            {
                CustomForce = vec3(0.0);
                // custom force formula example - Attract / Repel
                CustomForce += calculateForceAttractRepel(ForceOrigin, ParticleSpawnPosition, Strength);
            }
        CustomForce:
          IOType: 1
          Wireless: true
          Variable: [0.0, 0.0, 0.0]
        Description:
          ClassType1: TEXT
          String: |-
            Computes a Custom Force for GPU particles.
            
            This code node includes an example using Attract / Repel force, which is also found in the VFX graph. You can write your own force using this graph.
        Examples:
          ItemIndex: 0
          ItemList: "Custom : Input/Output/Global Types : Extra Functions : Procedural Execution : Lighting Loop : System Built-In Values/Functions"
        ForceOrigin:
          Connection0:
            NodeLevelID: 214
            PortID: Output
          Variable: [0.0, 0.0, 0.0]
        ID:
          Variable: 223
        Locked:
          Variable: false
        ParticleSeed:
          Connection0:
            NodeLevelID: 181
            PortID: particleSeed
          Wireless: true
          Variable: [0.0, 0.0, 0.0]
        ParticleSpawnPosition:
          Connection0:
            NodeLevelID: 47
            PortID: ParticleSpawnPosition
          Variable: [0.0, 0.0, 0.0]
        Stage:
          ItemIndex: 1
          ItemList: "Vertex : Pixel"
        Strength:
          Connection0:
            NodeLevelID: 210
            PortID: Output
          Variable: -10.0
        Title:
          String: Custom Force (EDIT ME)
        ngs_Height:
          Variable: 400
        ngs_Version:
          String: 2.2.0
        timeValues:
          Connection0:
            NodeLevelID: 181
            PortID: timeValues
          Wireless: true
          Variable: [0.0, 0.0, 0.0, 0.0]
      PositionX: -3917
      PositionY: 4830
      TemplateID: node_util_custom
      TemplateVersionMinor: 2
      Title1: Custom Force (EDIT ME)
