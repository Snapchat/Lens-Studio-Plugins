        lifeTimeConstant:
          Connection0:
            NodeLevelID: 9
            PortID: Output
          Variable: 0.0
        lifeTimeMinMax:
          Connection0:
            NodeLevelID: 10
            PortID: Output
          Variable: [0.0, 0.0]
        ngs_Height:
          Variable: 400
