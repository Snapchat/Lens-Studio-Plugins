      Title1: Interpolate
    Node145:
      DependencyIndex: 145
      LevelID: 2
      NodeCount: 0
      NodeType: 1
      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            // VERSION NOTES:
            // 2.2.1:   - remove quantization on color ramp textures
            // 2.1.1:	- fixed texturing on trails
            // 2.1.0:   - added trail features
            // 2.0.4:   - fixed Flipbook calculation
            //          - minor optimization: moved flipbook & colorramp calculations behind ENABLE bools
            // 2.0.3:   - updated code node version and random calculation
            // 2.0.2:   - added Fade to Camera parameter back in from Legacy
            // 2.0.0:   - restructured GPU Particles into 2 Code Nodes (Vertex and Pixel)
            //          - changed mesh to single quad and restructured to use instancing.
            //          - changed the way the particle seed is calculated.
            //          - added "ENABLE_" prefix to all static bools to avoid static bool code node name conflict / bug
            //          - deprecated Vector Blend -> users can instead use the Flipbook Motion Vectors Blend subgraph
            // 1.1.1:   - Added Vector Blend
            // 0.1.1:   - Deleted unnecessary line.
            //          - Added a isFallbackMode for the colorRampTex,
            //            a temporary solution until there is a fix in STUDIO-36480
            
            // Trails
            input_bool ENABLE_TRAILS;
            input_bool ENABLE_INDEPENDENTTRAIL;
            input_bool isTrailCondition;
            input_bool ENABLE_TRAILTEXTURE;
            input_texture_2d trailTexture;
            input_bool ENABLE_TRAILCOLORRAMP;
            input_texture_2d trailColorRampTex;
            input_vec4 fadeInOut;
            input_float trailLength;
            
            // Color
            input_vec3 colorStart;
            input_vec3 colorEnd;
            input_bool ENABLE_COLORMINMAX;
            input_vec3 colorMinStart;
            input_vec3 colorMinEnd;
            input_vec3 colorMaxStart;
            input_vec3 colorMaxEnd;
            input_bool ENABLE_COLORMONOMIN;
            
            // Alpha
            input_float alphaStart;
            input_float alphaEnd;
            input_bool ENABLE_ALPHAMINMAX;
            input_float alphaMinStart;
            input_float alphaMinEnd;
            input_float alphaMaxStart;
            input_float alphaMaxEnd;
            input_bool ENABLE_ALPHADISSOLVE;
            input_float alphaDissolveMult;
            input_bool ENABLE_PREMULTIPLIEDCOLOR;
            input_bool ENABLE_BLACKASALPHA;
            input_bool ENABLE_SCREENFADE;
            
            // Flipbook
            input_bool ENABLE_FLIPBOOK;
            input_texture_2d mainTexture;
            input_float numValidFrames;
            input_vec2 gridSize;
            input_float flipBookSpeedMult;
            input_float flipBookRandomStart;
            input_bool ENABLE_FLIPBOOKBLEND;
            input_bool ENABLE_FLIPBOOKBYLIFE;
            
            // Vector Blend - deprecated (2.0.0)
            
            // Color Ramp Tex
            input_bool ENABLE_COLORRAMP;
            input_texture_2d colorRampTexture;
            input_vec2 texSize;
            input_vec4 colorRampMult;
            input_bool ENABLE_NORANDOFFSET;
            
            // Pixel Shader Final
            input_bool ENABLE_BASETEXTURE;
            input_texture_2d mainTexture;
            
            // Shared with Vertex Shader
            // xy = realLifeTimeMinMax.xy, z = localTime, w = normTime
            input_bool ENABLE_WORLDPOSSEED;
            input_float externalSeed;
            input_vec4 timeValuesIn;
            input_vec4 cameraFade_trailHeadTime_taper;
            
            // Output
            output_vec3 particleSeed;
            output_float globalSeed;
            output_vec4 timeValues;
            output_vec4 result;
            output_vec2 uv;
            output_float isTrail;
            // x = trail head localtime, w = trail head normTime
            output_vec2 trailHeadTime;
            
            const float EPSILON = 1e-6;
            
            vec2 getFlipbookCoord( in vec2 CoordsIn, in vec2 SpriteCount, in float MaxFrames, in float FrameOffset, in float Speed, in float timeElapsed)
            { 
                vec2 CoordsOut;
            	float x = floor( SpriteCount.x );
            	float y = floor( SpriteCount.y );
            	float width = 1.0 / x;
            	float height = 1.0 / y;
            	float numFrames = min(x * y, floor(MaxFrames));
                // typically formula includes a SecondsOffset (timeElapsed + SecondOffset), but GPU Particles doesn't need it
            	float frame = floor(mod((timeElapsed) * Speed + floor(FrameOffset), numFrames));
            	float row = floor(frame / x);
            	float col = mod(frame, x);
            	return vec2( width * CoordsIn.x + col * width, 1.0 - height - row * height + height * CoordsIn.y );
            }
            
            void main()
            {
                ///////////////////////////////////////////////////////////////////////////
                //  RANDOMIZED VARIABLES
                ///////////////////////////////////////////////////////////////////////////
                // Seeds
                float worldPosSeed = 0.0;
                if (ENABLE_WORLDPOSSEED) { worldPosSeed = length(vec4(1.0, 1.0, 1.0, 1.0) * system.getMatrixWorld()); }
                globalSeed = externalSeed + worldPosSeed;
            
                // 2.0.0 Change particles to use instancing
                // Previously, each particle's ID was stored as a color and calculated using the following formula:
                //      vec4 color = system.getSurfaceColor();
                //      float colorRGB = color.r + color.g * color.b;
                // colorRGB has been replaced with vec3 particleSeed
            	// 2.0.1 use new better random calculation (no longer need mod)
                particleSeed = system.getRandomVec3(float(system.getInstanceID()));
            
                // Time
                float normTime = timeValuesIn.w;
            
                // Color
                float randPosX = particleSeed.x; //fract(instanceRatio * 82.12423 + globalSeed);
                float randPosY = particleSeed.y; //fract(instanceRatio * 9115.215 + globalSeed);
                float randPosZ = particleSeed.z; //fract(instanceRatio * 654.1559 + globalSeed);
                vec3 randColor = fract(vec3(randPosX, randPosY, randPosZ) * 27.21883 + globalSeed);
                if (ENABLE_COLORMONOMIN) { randColor = fract(vec3(randPosX, randPosX, randPosX) * 27.21883 + globalSeed); }
            
                // Alpha
                float randAlpha = fract(particleSeed.x * 3121.33313 + globalSeed);
            
                // Flipbook
                float randFlipbook = fract(particleSeed.y * 13.2234 + globalSeed);
                float randTime = fract(particleSeed.z * 3.5358 + globalSeed);
            
                ////////////////////////////////////////////////////////////////////////
                //  TRAILS
                ////////////////////////////////////////////////////////////////////////
                isTrail = 0.0;
                float fadeTrail = 1.0;
                trailHeadTime = cameraFade_trailHeadTime_taper.yz; // localtime and normtime of head particle
                vec4 trailColor = vec4(1.0);
                uv = system.getSurfaceUVCoord0();
            
                if(ENABLE_TRAILS)
                {
                    if(isTrailCondition)
                    {
                        isTrail = 1.0;
            
                        // apply taper
                        float taper = cameraFade_trailHeadTime_taper.w;
                        vec2 taperBounds = vec2(0.5 - taper / 2.0, 0.5 + taper / 2.0);
                        if(uv.x < taperBounds.x || uv.x > taperBounds.y) discard;
                        // remap uvs to tapered uvs
                        uv = vec2(system.remap(uv.x, taperBounds.x, taperBounds.y, 0.0, 1.0), uv.y);
            
                        if(ENABLE_TRAILTEXTURE) { trailColor = trailTexture.sample(vec2(uv.x, 1.0 - uv.y)); }
            
                        // fade ends of trail
                        float fadeControl = max(EPSILON, fadeInOut.x);
                        float trailNormTime = timeValuesIn.w; // always use trail's normTime regardless of behavior setting
                        fadeTrail *= mix(0.0, 1.0, clamp(trailNormTime, 0.0, fadeControl) / fadeControl); // fade in
                        fadeControl = max(EPSILON, fadeInOut.y);
                        fadeTrail *= mix(0.0, 1.0, clamp(1.0 - trailNormTime, 0.0, fadeControl) / fadeControl); // fade out
            
                        // fade entire trail
                        if(!ENABLE_INDEPENDENTTRAIL) {
                            // override normTime to be trailHeadTime
                            normTime = trailHeadTime.y;
                            fadeControl = max(EPSILON, fadeInOut.z);
                            fadeTrail *= mix(0.0, 1.0, clamp(normTime, 0.0, fadeControl) / fadeControl); // fade in
                            fadeControl = max(EPSILON, fadeInOut.w);
                            fadeTrail *= mix(0.0, 1.0, clamp(1.0 - normTime, 0.0, fadeControl) / fadeControl); // fade out
                        }
            
                        if(ENABLE_TRAILCOLORRAMP)
                        {
                            // 2.2.1: remove quantization that was happening on the color ramp to allow smooth color interpolation
                            trailColor *= trailColorRampTex.sample(vec2(normTime, 0.5));
                        }
                    }
                }
                
                ///////////////////////////////////////////////////////////////////////////
                //  COLOR / ALPHA
                ///////////////////////////////////////////////////////////////////////////
                vec4 colorLife;
            
                vec3 colorStartRandom = vec3(0.0);
                vec3 colorEndRandom = vec3(0.0);
                float alphaStartRandom = 0.0;
                float alphaEndRandom = 0.0;
                if (ENABLE_COLORMINMAX)
                {
                    colorStartRandom = mix(colorMinStart, colorMaxStart, randColor);
                    colorEndRandom = mix(colorMinEnd, colorMaxEnd, randColor);
                }
                else
                {
                    colorStartRandom = colorStart;
                    colorEndRandom = colorEnd;
                }
            
                if (ENABLE_ALPHAMINMAX)
                {
                    alphaStartRandom = mix(alphaMinStart, alphaMaxStart, randAlpha);
                    alphaEndRandom = mix(alphaMinEnd, alphaMaxEnd, randAlpha);
                }
                else
                {
                    alphaStartRandom = alphaStart;
                    alphaEndRandom = alphaEnd;
                }
                
                colorStartRandom = mix(colorStartRandom, colorEndRandom, normTime);
                alphaStartRandom = mix(alphaStartRandom, alphaEndRandom, normTime);
                
                colorLife = vec4(colorStartRandom.rgb, alphaStartRandom);
            
                ///////////////////////////////////////////////////////////////////////////
                //  TEXTURES
                ///////////////////////////////////////////////////////////////////////////
            
                // ------ Flipbook --------------------------------------------------------
                vec4 flipbookTex;
                vec2 flipUV0;
            
                if(ENABLE_BASETEXTURE)
                {
                    if (ENABLE_FLIPBOOK)
                    {
                        flipUV0 = system.getSurfaceUVCoord0();
                        vec2 flipUV1 = flipUV0;
                        float templifeMin = max(timeValuesIn.x, EPSILON); // realLifeTimeMinMax.x -> timeValuesIn.x
                        float templifeMax = max(timeValuesIn.y, EPSILON); // realLifeTimeMinMax.y -> timeValuesIn.y
                        float localTimeValue = timeValuesIn.z; // localTime -> timeValuesIn.z
            
                        if (ENABLE_FLIPBOOKBYLIFE)
                        {
                            float lifetime = mix(templifeMin, templifeMax, randTime);
                            localTimeValue /= lifetime;
                        }
                        // Flipbook Random Start
                        float flipbookRandOffset = floor((flipBookRandomStart + 1.0 ) * randFlipbook);
            
                        flipUV0 = getFlipbookCoord(flipUV0, gridSize, numValidFrames, flipbookRandOffset, flipBookSpeedMult, localTimeValue);
                        flipbookTex = mainTexture.sample(flipUV0);
            
                        if(ENABLE_FLIPBOOKBLEND)
                        {
                            flipUV1 = getFlipbookCoord(flipUV1, gridSize, numValidFrames, floor(mod(flipbookRandOffset + 1.0, numValidFrames)), flipBookSpeedMult, localTimeValue);
                            flipbookTex = mix(flipbookTex, mainTexture.sample(flipUV1), fract(localTimeValue * flipBookSpeedMult + flipbookRandOffset));
                        }
                    }
                }
            
                // ------ Color Ramp ------------------------------------------------------
                vec4 colorRampTex = vec4(1.0);
                if(ENABLE_COLORRAMP)
                {
                    // 2.2.1: remove quantization that was happening on the color ramp to allow smooth color interpolation
                    float varColorRampU = normTime;
                    if (ENABLE_NORANDOFFSET) { varColorRampU += system.getSurfaceUVCoord0().x / texSize.x; }
                    colorRampTex = colorRampTexture.sample(vec2(varColorRampU, 0.5)) * colorRampMult;
                }
            
                ////////////////////////////////////////////////////////////////////////
                //  CALCULATE PIXEL COLOR
                ////////////////////////////////////////////////////////////////////////
                vec4 albedo = vec4(1.0, 1.0, 1.0, 1.0);
                vec4 colorRampTexValue = vec4(1.0, 1.0, 1.0, 1.0);
            
                if (ENABLE_BASETEXTURE)
                {
                    if (ENABLE_FLIPBOOK)
                    {
                        uv = flipUV0;
                        albedo = flipbookTex;
                    }
                    else
                    {
                        albedo = mainTexture.sample(uv);
                    }
                }
              
                if (ENABLE_COLORRAMP)
                {
                    if (!system.isFallbackMode()) { colorRampTexValue = colorRampTex; }
                }
            
                result = albedo * colorLife * colorRampTexValue;
            
                if(ENABLE_TRAILS)
                {
                    if(isTrail > 0.0) {
                        result = trailColor * colorLife * colorRampTexValue;
                        result.a *= fadeTrail;
                    }
                }
            
                if (ENABLE_SCREENFADE) { result.a *= cameraFade_trailHeadTime_taper.x; }
            
                if (ENABLE_ALPHADISSOLVE)
                {
                    float varDissolve = normTime * alphaDissolveMult;
                    result.a = clamp(result.a - varDissolve, 0.0, 1.0);
                }
                
                //Premultiplied Alpha
                if (ENABLE_BLACKASALPHA)
                {
                    float alphaFromRGB = length(result.rgb);
                    result.a = alphaFromRGB;
                    if(ENABLE_TRAILS) result.a *= fadeTrail;
                }
            
                if (ENABLE_PREMULTIPLIEDCOLOR) { result.rgb = result.rgb * result.a; }
            
                // output time values
                timeValues = timeValuesIn;
            }
        Description:
          ClassType1: TEXT
          String: ""
        ENABLE_ALPHADISSOLVE:
          Connection0:
            NodeLevelID: 72
            PortID: Output
          Variable: 0.0
