      LevelID: 113
      NodeCount: 0
      NodeType: 1
      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            input_int MESHTYPE;
            input_bool USENORMALMAP;
            input_vec3 NormalFromTex;
            output_vec3 Normal_TangentSpace; 
            
            void main()
            {
            	Normal_TangentSpace = vec3(0.0, 0.0, 1.0);
            
            	// only use normal data if meshtype is 3D mesh
            	if(MESHTYPE == 1)
            	{
            		if(USENORMALMAP)
            		{
            			Normal_TangentSpace = NormalFromTex;
            		}
            	}
            }
