        SpecifySpecConst:
          Variable: true
        Static:
          Variable: true
        Tooltip:
          String: |-
            CAUTION! not supported by Low-End Mobile devices (size will become 0 on Low-End devices).
            \n\nInterpolates the size of the particle between [0, Size Start] over the particle's lifetime. If using Size Random, the upper bound is randomized between [Size Start, Size Start Max]. The texture is read from left to right over the particle's lifetime.\n - Quad: Uses R and G values from texture to apply X and Y scale, respectively.\n - 3D Mesh: Uses R, G, and B values from texture to apply X, Y, and Z scale, respectively.
        UniqueID:
          String: Size Ramp Texture
