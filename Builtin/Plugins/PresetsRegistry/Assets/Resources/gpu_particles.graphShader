    Node64:
      DependencyIndex: 64
      LevelID: 181
      NodeCount: 0
      NodeType: 1
      Ports:
        Code:
          ClassType1: TEXT
          String: |-
            // VERSION NOTES:
            // 2.2.0:   - added controls for constant spawn
            //          - added ability to enable or disable "prewarm" (GPU particles used to always run as if pre-warmed)
            // 2.1.1:   - fix spawn duration when global time != 1
            // 2.1.0:   - added trail controls
            //          - renamed particleAlive to particleAlive for clarity (acts like a bool)
            // 2.0.2:	- upgraded code node and updated random value calculation
            // 2.0.1:   - separated Time and Lifetime variables to a new Code Node
            // 2.0.0:   - restructured GPU Particles into 2 Code Nodes (Vertex and Pixel)
            //          - changed mesh to single quad and restructured to use instancing.
            //          - changed the way the particle seed is calculated.
            
            // Time / Spawn
            input_float timeGlobal;
            input_bool ENABLE_EXTERNALTIME;
            input_float externalTime;
            input_bool ENABLE_WORLDPOSSEED;
            input_float externalSeed;
            input_bool ENABLE_LIFETIMEMINMAX;
            input_float lifeTimeConstant;
            input_vec2 lifeTimeMinMax;
            input_bool ENABLE_INSTANTSPAWN;
            input_bool ENABLE_CONSTANTSPAWN;
            input_bool ENABLE_PREWARM;
            input_float spawnDuration;
            input_bool ENABLE_TRAILS;
            input_float trailLength;
            input_bool isTrailCondition;
            input_bool ENABLE_INDEPENDENTTRAIL;
            
            output_vec3 particleSeed;
            output_float globalSeed;
            output_float particleAlive;
            // xy = lifeTimeMinMax.xy, z = localTime, w = normTime
            output_vec4 timeValues;
            output_float isTrail;
            output_vec2 trailHeadTime;
            
            void main()  
            {
                // Seeds
                float worldPosSeed = 0.0;
                vec3 defValue = vec3(0.0, 0.0, 0.0);
                if (ENABLE_WORLDPOSSEED)
                {
                    worldPosSeed = length(vec4(1.0, 1.0, 1.0, 1.0) * system.getMatrixWorld());
                }
                globalSeed = externalSeed + worldPosSeed;
            
                // 2.0.0 Change particles to use instancing
                // Previously, each particle's ID was stored as a color and calculated using the following formula:
                //      vec4 color = system.getSurfaceColor();
                //      float colorRGB = color.r + color.g * color.b;
                // colorRGB has been replaced with vec3 particleSeed
                // 2.0.1 use new better random calculation, only needs instanceID as input
                particleSeed = system.getRandomVec3(float(system.getInstanceID()));
            
                // Spawn Time / Rate / Location
                float randSpawn = fract(particleSeed.y * 12.12358 + globalSeed);
                float randTime = fract(particleSeed.z * 3.5358 + globalSeed);
                float randspawnRate = fract(particleSeed.x * 1231.123123 + globalSeed);
            
                // Lifetime
                vec2 realLifeTimeMinMax = ENABLE_LIFETIMEMINMAX ? lifeTimeMinMax : vec2(lifeTimeConstant);
                float templifeMin = max(realLifeTimeMinMax.x, 0.01);
                float templifeMax = max(realLifeTimeMinMax.y, 0.01);
            
                // Time
                float time = system.getTimeElapsed();
            
                if (ENABLE_EXTERNALTIME)
                {
                    time = externalTime;
                }
            
                float localTime = time;
                if (ENABLE_INSTANTSPAWN)
                {
                    localTime = timeGlobal * time;
                }
                else
                {
                    float extendLife = 0.0;
                    if(ENABLE_TRAILS)
                    {
                        if(ENABLE_INDEPENDENTTRAIL) extendLife = trailLength;
                    }
            
                    // 2.2.0: constant spawn controls
                    float randSpawn = 0.0;
                    if (ENABLE_CONSTANTSPAWN) 
                    {
                        randSpawn = max(system.getInstanceRatio() * (1.0 - (1.0/float(system.getInstanceCount()))), 0.0);
                    }
                    else
                    {
                        randSpawn = fract(particleSeed.y * 12.12358 + globalSeed);
                    }
            
                    float constSpawn = fract((time * timeGlobal) * (1.0 / (realLifeTimeMinMax.y + extendLife)) + randSpawn);
                    localTime = constSpawn * (realLifeTimeMinMax.y + extendLife); 
                }
            
                float normTimeMult = mix(localTime / templifeMin, localTime / templifeMax, randTime);
                float normTime = clamp(normTimeMult, 0.0, 1.0);
            
                // 2.1.0: trails
                isTrail = 0.0;
                trailHeadTime = vec2(localTime, normTime);
                
                if (ENABLE_TRAILS) {
                    if(isTrailCondition) {
                        isTrail = 1.0;
                        // recalculate time used for positioning and driving effects
                        localTime -= (system.getSurfaceUVCoord0().y) * trailLength;
                        normTimeMult = mix(localTime / templifeMin, localTime / templifeMax, randTime);
                        normTime = clamp(normTimeMult, 0.0, 1.0);
                    }
                }
            
                // Spawn
                float spawnControl = 0.0;
                if (!ENABLE_INSTANTSPAWN)
                {
                    if (spawnDuration > 0.0)
                    {
                        // 2.1.1 - fix spawn duratioin when timeGlobal is != 1 (note that the check is still based on elapsed time)
                        // for trails: the trail heads will stop spawning, but the tails are allowed to finish
                        if ((time - spawnDuration ) * timeGlobal >= trailHeadTime.x)
                        {
                            spawnControl = 1.0;
                        }
                    }
                }
            
                // Particle Alive or Not
                float dieController = normTimeMult + spawnControl;
                particleAlive = 1.0;
                if (dieController > 0.9999 || localTime <= 0.0){ particleAlive = 0.0; }
            
                // 2.2.0: allow particles to spawn in instead of starting pre-warmed
                if(!ENABLE_PREWARM)
                {
                    particleAlive *= step(trailHeadTime.x, time * timeGlobal - 0.0001);
                }
            
                timeValues = vec4(realLifeTimeMinMax, localTime, normTime);
            }
        Description:
          ClassType1: TEXT
          String: |
            Calculates the particle seed, time, and spawn conditions for Vertex Shader Particles.
            
            These controls can help with performing vertex-level calculations -- such as vertex animation -- that are changed over the particle's life.
            
            Output Variables:
            * Particle Seed: the xyz particle seed variable used to create randomness.
            * Global Seed: particle seed shared by the entire particle system, but which allows it to differ from other systems.
            * Particle Alive: whether the current particle is alive (1.0) or not (0.0)
            * Time Values: The values for the particles Min and Max lifetime (xy), Local Time (z), and Normal Time (w)
            * Trail Head Time: when trails are enabled, gives the time values for the leading particle: Local Time (x) and NormTime (y).

        ENABLE_CONSTANTSPAWN:
          Connection0:
            NodeLevelID: 222
            PortID: Output
          Variable: 1.0
        ENABLE_EXTERNALTIME:
          Connection0:
            NodeLevelID: 6
            PortID: Output
          Variable: 0.0
        ENABLE_INDEPENDENTTRAIL:
          Connection0:
            NodeLevelID: 167
            PortID: Output
          Wireless: true
          Variable: 0.0
        ENABLE_INSTANTSPAWN:
          Connection0:
            NodeLevelID: 11
            PortID: Output
          Variable: 0.0
        ENABLE_LIFETIMEMINMAX:
          Connection0:
            NodeLevelID: 0
            PortID: Output
          Variable: 0.0
        ENABLE_PREWARM:
          Connection0:
            NodeLevelID: 225
            PortID: Output
          Variable: 0.0
        ENABLE_TRAILS:
          Connection0:
            NodeLevelID: 70
            PortID: Output
          Variable: 0.0
        ENABLE_WORLDPOSSEED:
          Connection0:
            NodeLevelID: 8
            PortID: Output
          Variable: 0.0
        Examples:
          ItemIndex: 0
          ItemList: "Custom : Input/Output/Global Types : Extra Functions : Procedural Execution : Lighting Loop : System Built-In Values/Functions"
        ID:
          Variable: 181
        Locked:
          Variable: true
        Stage:
          ItemIndex: 1
          ItemList: "Vertex : Pixel"
        Title:
          String: "Particle Seed, Time, and Spawn"
        externalSeed:
          Connection0:
            NodeLevelID: 7
            PortID: Output
          Variable: 0.0
        externalTime:
          Connection0:
            NodeLevelID: 5
            PortID: Output
          Variable: 0.0
        globalSeed:
          IOType: 1
          Variable: 0.0
        isTrail:
          IOType: 1
          Variable: 0.0
        isTrailCondition:
          Connection0:
            NodeLevelID: 218
